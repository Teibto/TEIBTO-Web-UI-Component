# Secrets — R6 (teibto-dev-standards): no credentials in git, ever
.env*
!.env.example
*.key
*.pem
.qa-profiles/

# SDF project folder (local SuiteCloud staging area for NetSuite upload)
sdf/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Node
node_modules/

# Build output (regenerated by `npm run build`)
# Use `dist/*` so per-file !-exceptions below actually work
# (git cannot re-include a file under an excluded directory).
dist/*
# Exception: tbt-page-runtime.js is hand-authored, not built — must be tracked.
!dist/tbt-page-runtime.js

# Playwright
/test-results/
/playwright-report/
