# .env.example — template สำหรับ .env (local dev เท่านั้น, .env ถูก git-ignore)
# copy เป็น .env แล้วกรอกค่า — ห้าม commit ค่าจริงเด็ดขาด (R6)

# ─── Developer SB (teibto-sb2) ───────────────────────────────────────────────
NS_ACCOUNT_ID=
NS_BASE_URL=
# NetSuite login — email + password ของ user ใน teibto-sb2
NS_EMAIL=
NS_PASSWORD=
# TOTP: ถ้า user นี้เปิด 2FA ให้ใส่ base32 seed; ถ้าปิดอยู่ ให้ comment ออก
NS_TOTP_SECRET=
